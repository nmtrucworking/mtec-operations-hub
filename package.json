{
  "name": "mtec-operations-hub",
  "private": true,
  "version": "2.1.2",
  "description": "Hệ thống quản trị vận hành và nhân sự toàn diện dành cho CLB MTEC NTTU",
  "author": "MTEC Executive Board",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "db:reset": "psql \"$DATABASE_URL\" -v confirm_reset=1 -f scripts/database/reset_database.sql",
    "db:seed:members": "psql \"$DATABASE_URL\" -f scripts/database/seed_members.sql",
    "db:handover": "npm run db:reset && npm run db:seed:members"
  },
  "dependencies": {
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^2.30.0",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.542.0",
    "react": "^19.1.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^19.1.1",
    "react-i18next": "^17.0.4",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "react-router-dom": "^6.30.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vite": "^7.1.5"
  }
}
